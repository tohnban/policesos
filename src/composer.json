{
    "name": "tohnban/imobil",
    "description": "Plataforma imobiliária em PHP MVC: catálogo de imóveis, solicitações, comissões, afiliação e painel administrativo.",
    "type": "project",
    "keywords": [
        "imobiliario",
        "real-estate",
        "php",
        "mvc",
        "marketplace"
    ],
    "homepage": "https://github.com/tohnban/imobil",
    "readme": "../README.md",
    "authors": [
        {
            "name": "Antonio Nzage Banduenga",
            "email": "antoniobanduenga@gmail.com",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/tohnban/imobil/issues",
        "source": "https://github.com/tohnban/imobil"
    },
    "require": {
        "php": "^8.0",
        "phpmailer/phpmailer": "^6.5",
        "dompdf/dompdf": "^2.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/phpstan": "^1.12"
    },
    "autoload": {
        "psr-4": {
            "App\\": "../app/",
            "Src\\": "../src/"
        }
    },
    "scripts": {
        "quality:cs": "php-cs-fixer fix --dry-run --diff --allow-risky=yes",
        "quality:cs-fix": "php-cs-fixer fix --allow-risky=yes",
        "quality:stan": "phpstan analyse -c ../phpstan.neon.dist --memory-limit=512M",
        "quality": [
            "@quality:cs",
            "@quality:stan"
        ],
        "production-deps": "composer install --no-dev --optimize-autoloader --no-interaction"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
