# =============================================================================
# Imobil — variáveis de ambiente (PRODUÇÃO)
# Copie para .env no servidor e preencha todos os valores marcados com CHANGE_ME.
# Nunca versionar o ficheiro .env real.
# =============================================================================

# Database
DB_HOST=CHANGE_ME
DB_PORT=3306
DB_NAME=imobil_db
DB_USER=CHANGE_ME
DB_PASS=CHANGE_ME
DB_PERSISTENT=true

# Application — obrigatório em produção
APP_ENV=production
APP_URL=https://www.seudominio.ao
APP_DEBUG=false
SESSION_LIFETIME=3600

# Security
CSRF_TOKEN_LENGTH=32
PASSWORD_HASH_ALGO=bcrypt

# Logging
LOG_CHANNEL=file
LOG_LEVEL=warning

# Email — activar em produção
EMAIL_ENABLED=true
MAIL_FROM_ADDRESS=no-reply@seudominio.ao
MAIL_FROM_NAME=Imobil
SMTP_HOST=CHANGE_ME
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
SMTP_SECURE=tls
