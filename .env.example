# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=imobil_db
DB_USER=root
DB_PASS=

# Application Settings
APP_ENV=development
APP_URL=http://localhost
APP_DEBUG=true
SESSION_LIFETIME=1800

# Security
CSRF_TOKEN_LENGTH=32
PASSWORD_HASH_ALGO=bcrypt

# Logging
LOG_CHANNEL=file
LOG_LEVEL=info

# Email Notifications
EMAIL_ENABLED=false
MAIL_FROM_ADDRESS=no-reply@imobil.local
MAIL_FROM_NAME=Imobil
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=